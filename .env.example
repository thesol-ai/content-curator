# ══════════════════════════════════════════════════════════════
# .env.example — فقط برای reference
# هیچ‌وقت مقادیر واقعی را commit نکنید!
# همه secrets را با `wrangler secret put` تنظیم کنید.
# این فایل باید در .gitignore باشد اگر مقادیر واقعی دارد.
# ══════════════════════════════════════════════════════════════

# ── Secrets (wrangler secret put KEY --env production) ────────
APIFY_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ
INTERNAL_API_SECRET=<حداقل ۳۲ کاراکتر تصادفی — openssl rand -hex 32>

# ── Local development (در wrangler.toml تنظیم می‌شوند) ───────
ENVIRONMENT=local
APIFY_CURATION_ENABLED=false
APIFY_CURATION_DRY_RUN=true
TELEGRAM_FINAL_PUBLISH_ENABLED=false
TELEGRAM_PUBLISH_SCHEDULER_ENABLED=false

# ── AI Scoring (Claude) ───────────────────────────────────────
AI_SCORING_MODEL=claude-haiku-4-5-20251001
AI_SCORE_THRESHOLD_DEFAULT=75
AI_MAX_CALLS_PER_DAY=10
AI_DAILY_TOKEN_BUDGET=50000
AI_MAX_CANDIDATES_PER_RUN=50

# ── AI Translation ────────────────────────────────────────────
# TRANSLATION_PROVIDER: gemini | openai | claude
TRANSLATION_PROVIDER=gemini
# Gemini: gemini-2.5-flash-lite, gemini-2.5-flash, gemini-2.5-pro
# OpenAI: gpt-4.1-nano, gpt-4o-mini, gpt-4.1-mini
TRANSLATION_MODEL=gemini-2.5-flash-lite
